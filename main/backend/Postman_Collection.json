    {
      "name": "2. Providers",
      "item": [
        {
          "name": "Create Provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    // Response format: {success, statusCode, message, data: {provider: {...}}}",
                  "    const provider = response.data.provider;",
                  "    if (provider && provider._id) {",
                  "        const providerId = provider._id;",
                  "        pm.collectionVariables.set('providerId', providerId);",
                  "        console.log('✅ Provider ID saved:', providerId);",
                  "        console.log('✅ ID length:', providerId.length, '(expected: 24)');",
                  "        ",
                  "        // Validate ObjectId length",
                  "        if (providerId.length !== 24) {",
                  "            console.error('❌ WARNING: Provider ID has wrong length!');",
                  "            console.error('   Expected: 24 characters');",
                  "            console.error('   Got:', providerId.length, 'characters');",
                  "        }",
                  "    } else {",
                  "        console.error('❌ Could not extract provider ID from response:', response);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Healthcare Clinic\",\n  \"description\": \"Professional healthcare services\",\n  \"contactEmail\": \"contact@clinic.com\",\n  \"contactPhone\": \"+1234567892\",\n  \"address\": \"123 Main St, City, State 12345\",\n  \"timezone\": \"America/New_York\"\n}"
